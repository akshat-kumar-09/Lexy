# Copy to .env.local and fill in real values. Never commit .env.local.

# Clerk — https://dashboard.clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Neon Postgres — pooled connection string (Dashboard → Connect)
